<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="6" author="laura">
        <createTable tableName="detalle_venta">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="venta_id" type="BIGINT"/>
            <column name="medicamento_id" type="BIGINT"/>
            <column name="cantidad" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="precio_unitario" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="subtotal" type="DECIMAL(10,2)"/>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="detalle_venta"
            baseColumnNames="venta_id"
            referencedTableName="venta"
            referencedColumnNames="id"
            constraintName="fk_detalle_venta"/>
        <addForeignKeyConstraint
            baseTableName="detalle_venta"
            baseColumnNames="medicamento_id"
            referencedTableName="medicamento"
            referencedColumnNames="id"
            constraintName="fk_detalle_medicamento"/>
    </changeSet>

</databaseChangeLog>