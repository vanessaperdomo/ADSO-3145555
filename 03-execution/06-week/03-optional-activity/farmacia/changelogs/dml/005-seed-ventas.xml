<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="dml-005-seed-ventas" author="laura">
        <comment>Datos iniciales: ventas recientes de la farmacia</comment>

        <!-- Venta 1: Carlos Méndez — Efectivo -->
        <insert tableName="venta">
            <column name="cliente_id"   valueNumeric="1"/>
            <column name="fecha_venta"  valueDate="2026-03-15"/>
            <column name="total"        valueNumeric="13700.00"/>
            <column name="metodo_pago"  value="Efectivo"/>
            <column name="estado"       value="Completada"/>
        </insert>

        <!-- Venta 2: María Fernanda — Nequi -->
        <insert tableName="venta">
            <column name="cliente_id"   valueNumeric="2"/>
            <column name="fecha_venta"  valueDate="2026-03-16"/>
            <column name="total"        valueNumeric="25400.00"/>
            <column name="metodo_pago"  value="Nequi"/>
            <column name="estado"       value="Completada"/>
        </insert>

        <!-- Venta 3: Jorge Perdomo — Tarjeta -->
        <insert tableName="venta">
            <column name="cliente_id"   valueNumeric="3"/>
            <column name="fecha_venta"  valueDate="2026-03-17"/>
            <column name="total"        valueNumeric="11200.00"/>
            <column name="metodo_pago"  value="Tarjeta"/>
            <column name="estado"       value="Completada"/>
        </insert>

        <!-- Venta 4: Ana Torres — Efectivo -->
        <insert tableName="venta">
            <column name="cliente_id"   valueNumeric="4"/>
            <column name="fecha_venta"  valueDate="2026-03-17"/>
            <column name="total"        valueNumeric="8900.00"/>
            <column name="metodo_pago"  value="Efectivo"/>
            <column name="estado"       value="Completada"/>
        </insert>

        <!-- Venta 5: Cliente anónimo — Efectivo -->
        <insert tableName="venta">
            <column name="fecha_venta"  valueDate="2026-03-17"/>
            <column name="total"        valueNumeric="4800.00"/>
            <column name="metodo_pago"  value="Efectivo"/>
            <column name="estado"       value="Completada"/>
            <column name="observaciones" value="Venta sin cliente registrado"/>
        </insert>

        <rollback>
            <delete tableName="venta">
                <where>fecha_venta::date IN ('2026-03-15','2026-03-16','2026-03-17')</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
