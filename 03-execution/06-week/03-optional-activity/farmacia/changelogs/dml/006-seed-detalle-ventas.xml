<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="dml-006-seed-detalle-ventas" author="laura">
        <comment>Datos iniciales: líneas de detalle de las ventas</comment>

        <!-- Venta 1: Dolex Forte x2 + Loratadina x1 -->
        <insert tableName="detalle_venta">
            <column name="venta_id"        valueNumeric="1"/>
            <column name="medicamento_id"  valueNumeric="1"/>
            <column name="cantidad"        valueNumeric="2"/>
            <column name="precio_unitario" valueNumeric="4800.00"/>
            <column name="subtotal"        valueNumeric="9600.00"/>
        </insert>
        <insert tableName="detalle_venta">
            <column name="venta_id"        valueNumeric="1"/>
            <column name="medicamento_id"  valueNumeric="7"/>
            <column name="cantidad"        valueNumeric="1"/>
            <column name="precio_unitario" valueNumeric="2900.00"/>
            <column name="subtotal"        valueNumeric="2900.00"/>
        </insert>

        <!-- Venta 2: Losartán x2 + Metformina x1 + Omeprazol x1 -->
        <insert tableName="detalle_venta">
            <column name="venta_id"        valueNumeric="2"/>
            <column name="medicamento_id"  valueNumeric="5"/>
            <column name="cantidad"        valueNumeric="2"/>
            <column name="precio_unitario" valueNumeric="6000.00"/>
            <column name="subtotal"        valueNumeric="12000.00"/>
        </insert>
        <insert tableName="detalle_venta">
            <column name="venta_id"        valueNumeric="2"/>
            <column name="medicamento_id"  valueNumeric="6"/>
            <column name="cantidad"        valueNumeric="1"/>
            <column name="precio_unitario" valueNumeric="5200.00"/>
            <column name="subtotal"        valueNumeric="5200.00"/>
        </insert>
        <insert tableName="detalle_venta">
            <column name="venta_id"        valueNumeric="2"/>
            <column name="medicamento_id"  valueNumeric="8"/>
            <column name="cantidad"        valueNumeric="2"/>
            <column name="precio_unitario" valueNumeric="4200.00"/>
            <column name="subtotal"        valueNumeric="8400.00"/>
        </insert>

        <!-- Venta 3: Amoxicilina x1 + Ibuprofeno x1 -->
        <insert tableName="detalle_venta">
            <column name="venta_id"        valueNumeric="3"/>
            <column name="medicamento_id"  valueNumeric="3"/>
            <column name="cantidad"        valueNumeric="1"/>
            <column name="precio_unitario" valueNumeric="8900.00"/>
            <column name="subtotal"        valueNumeric="8900.00"/>
        </insert>
        <insert tableName="detalle_venta">
            <column name="venta_id"        valueNumeric="3"/>
            <column name="medicamento_id"  valueNumeric="2"/>
            <column name="cantidad"        valueNumeric="1"/>
            <column name="precio_unitario" valueNumeric="3500.00"/>
            <column name="subtotal"        valueNumeric="3500.00"/>
        </insert>

        <!-- Venta 4: Azitromicina x1 -->
        <insert tableName="detalle_venta">
            <column name="venta_id"        valueNumeric="4"/>
            <column name="medicamento_id"  valueNumeric="4"/>
            <column name="cantidad"        valueNumeric="1"/>
            <column name="precio_unitario" valueNumeric="16500.00"/>
            <column name="subtotal"        valueNumeric="16500.00"/>
        </insert>

        <!-- Venta 5 (anónima): Dolex Forte x1 -->
        <insert tableName="detalle_venta">
            <column name="venta_id"        valueNumeric="5"/>
            <column name="medicamento_id"  valueNumeric="1"/>
            <column name="cantidad"        valueNumeric="1"/>
            <column name="precio_unitario" valueNumeric="4800.00"/>
            <column name="subtotal"        valueNumeric="4800.00"/>
        </insert>

        <rollback>
            <delete tableName="detalle_venta">
                <where>venta_id IN (1,2,3,4,5)</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
