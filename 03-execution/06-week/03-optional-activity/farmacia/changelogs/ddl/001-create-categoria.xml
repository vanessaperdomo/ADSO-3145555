<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Tabla: categoria
        Clasifica los medicamentos por tipo terapéutico.
    -->
    <changeSet id="ddl-001-create-categoria" author="laura">
        <comment>Crea la tabla de categorías de medicamentos</comment>

        <createTable tableName="categoria" remarks="Clasificación terapéutica de los medicamentos">
            <column name="id" type="SERIAL" remarks="Identificador único autoincremental">
                <constraints primaryKey="true" primaryKeyName="pk_categoria" nullable="false"/>
            </column>
            <column name="nombre" type="VARCHAR(100)" remarks="Nombre de la categoría (ej: Analgésico, Antibiótico)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_categoria_nombre"/>
            </column>
            <column name="descripcion" type="TEXT" remarks="Descripción del uso terapéutico"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="categoria"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
