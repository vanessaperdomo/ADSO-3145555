<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Tabla: cliente
        Registro de los clientes de la farmacia.
    -->
    <changeSet id="ddl-004-create-cliente" author="laura">
        <comment>Crea la tabla de clientes de la farmacia</comment>

        <createTable tableName="cliente" remarks="Clientes registrados en la farmacia">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_cliente" nullable="false"/>
            </column>
            <column name="nombre" type="VARCHAR(100)" remarks="Nombre del cliente">
                <constraints nullable="false"/>
            </column>
            <column name="apellido" type="VARCHAR(100)" remarks="Apellido del cliente">
                <constraints nullable="false"/>
            </column>
            <column name="tipo_documento" type="VARCHAR(10)" remarks="CC, TI, CE, PA, NIT">
                <constraints nullable="false"/>
            </column>
            <column name="numero_documento" type="VARCHAR(20)" remarks="Número de identificación">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_cliente_documento"/>
            </column>
            <column name="telefono" type="VARCHAR(20)" remarks="Número de contacto"/>
            <column name="email" type="VARCHAR(150)" remarks="Correo electrónico">
                <constraints unique="true" uniqueConstraintName="uq_cliente_email"/>
            </column>
            <column name="fecha_nacimiento" type="DATE" remarks="Fecha de nacimiento del cliente"/>
            <column name="activo" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <sql>
            ALTER TABLE cliente
            ADD CONSTRAINT chk_cliente_tipo_documento
                CHECK (tipo_documento IN ('CC','TI','CE','PA','NIT'));
        </sql>

        <rollback>
            <dropTable tableName="cliente"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
